# Porta em que a API sobe (Railway injeta automaticamente via PORT)
PORT=3001

# String de conexão do PostgreSQL (Railway injeta via DATABASE_URL)
DATABASE_URL=postgresql://usuario:senha@host:5432/tripcontrol

# Segredos JWT — gere strings aleatórias longas e diferentes entre si
JWT_SECRET=troque-por-uma-string-aleatoria-longa
JWT_REFRESH_SECRET=troque-por-outra-string-aleatoria-longa
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL do frontend em produção — usada no CORS e nos links de convite
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
RESEND_API_KEY=
EMAIL_FROM=
